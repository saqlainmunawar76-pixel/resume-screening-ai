# Copy this file to ".env" and fill in your key to enable AI-generated text
# (resume summaries, interview questions, skill-gap analysis, chat assistant,
# resume improvement suggestions, hiring recommendations).
#
# Get a free Gemini API key from: https://aistudio.google.com/app/apikey
#
# The system works WITHOUT this key too -- it automatically falls back to
# rule-based logic for every AI feature. Adding the key just makes the
# generated text richer and more natural.

GEMINI_API_KEY=your_gemini_api_key_here
